<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="game.gui.controllers.RoleSelectionController"
           stylesheets="@../css/app.css"
           prefWidth="900" prefHeight="600">

    <VBox alignment="CENTER" spacing="40" styleClass="role-selection-root">


        <VBox alignment="CENTER" spacing="6">
            <Label text="Choose Your Side" styleClass="title-main"/>
            <Label text="Pick your role to begin the game" styleClass="title-sub"/>
        </VBox>


        <HBox alignment="CENTER" spacing="40">


            <VBox alignment="CENTER" spacing="12" styleClass="role-card role-card-scarer">
                <Label text="SCARER" styleClass="role-emoji"/>
                <Label text="SCARER" styleClass="role-title"/>
                <Label text="Aggressive and Powerful" styleClass="role-desc"/>
                <Label text="High damage - Strong passives" styleClass="role-hint"/>
                <Button text="SELECT SCARER" styleClass="btn-scarer"
                        onAction="#onScarerSelected" prefWidth="180"/>
            </VBox>


            <Label text="VS" styleClass="vs-label"/>


            <VBox alignment="CENTER" spacing="12" styleClass="role-card role-card-laugher">
                <Label text="LAUGHER" styleClass="role-emoji"/>
                <Label text="LAUGHER" styleClass="role-title"/>
                <Label text="Agile and Resourceful" styleClass="role-desc"/>
                <Label text="Fast movement - Energy tricks" styleClass="role-hint"/>
                <Button text="SELECT LAUGHER" styleClass="btn-laugher"
                        onAction="#onLaugherSelected" prefWidth="180"/>
            </VBox>

        </HBox>


        <Label fx:id="statusLabel" text="" styleClass="status-label"/>


        <Button text="BACK" styleClass="btn-back" onAction="#onBack"/>

    </VBox>

</StackPane>
